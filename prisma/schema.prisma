// Prisma schema 用来描述 MySQL 里的表结构。
// P11 开始接入真实登录用户，User / Conversation / Message / Document 都要围绕 userId 做数据隔离。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

/// User 是用户表。
/// email 用作登录账号；passwordHash 保存 bcrypt 加密后的密码，绝不能保存明文密码。
/// 一个用户可以有多个会话和多个文档，这是一对多关系。
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String         @default("")
  conversations Conversation[]
  documents     Document[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Conversation 是会话表。
/// 每个会话都通过 userId 绑定到某个用户，查询会话列表时必须带 userId，避免不同用户互相看到数据。
model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt])
}

/// Message 是消息表。
/// Message 通过 conversationId 归属于某个会话，而会话再归属于用户。
/// sources / answerMode / retrievalStatus / fallbackReason 用来保存 RAG 回答的结构化信息，刷新页面后仍能展示引用来源。
model Message {
  id              String       @id @default(cuid())
  conversationId  String
  role            String
  content         String       @db.Text
  sources         Json?
  answerMode      String?
  retrievalStatus String?
  fallbackReason  String?      @db.Text
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([conversationId, createdAt])
}

/// Document 是知识库文档表。
/// 文档也必须绑定 userId，P11 后每个用户只能上传、查看、索引、删除自己的文档。
/// parsedText 给 P6 分块和向量化使用；indexError 用来记录向量化失败原因。
model Document {
  id         String   @id @default(cuid())
  userId     String
  fileName   String
  fileType   String
  fileSize   Int?
  filePath   String
  status     String   @default("uploaded")
  parsedText String?  @db.LongText
  parseError String?  @db.Text
  indexError String?  @db.Text
  chunkCount Int      @default(0)
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
}
